# ── Secrets & environment ───────────────────────────────────────
.env
.env.local
.venv
# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.whl
.pytest_cache/
*.egg

# ── Large binary files (not source) ────────────────────────────
models/*
!models/.gitkeep
tools/llama/*
!tools/llama/.gitkeep

# ── Benchmark scripts (not for distribution) ──────────────────────────
benchmark/

# ── Input, generated output & cache ────────────────────────────────────
input/*
!input/.gitkeep
output/*
!output/.gitkeep
cache/*
!cache/.gitkeep


# ── IDE ─────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~

# ── Claude Code ────────────────────────────────────────────────
.claude/

# ── System junk ─────────────────────────────────────────────────
--local-dir
--local-dir/
Thumbs.db
.DS_Store
Desktop.ini
